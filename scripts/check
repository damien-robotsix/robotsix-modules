#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."
echo "=== lint ==="
"$(dirname "$0")/lint"
echo "=== deptry ==="
uv run deptry .
echo "=== bandit ==="
uv run bandit -c pyproject.toml -r src/
echo "=== uv audit ==="
uv audit
echo "=== pytest ==="
uv run pytest --cov --cov-report=xml --cov-report=term-missing
echo "=== check-registration ==="
uv run robotsix-modules check-registration docs/modules.yaml --root .
echo "=== mkdocs build --strict ==="
uv run --group docs mkdocs build --strict
echo "=== all checks passed ==="
