#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

VERSION="${1:-}"

if [ -z "$VERSION" ]; then
    echo "usage: scripts/release X.Y.Z" >&2
    exit 1
fi

if ! echo "$VERSION" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
    echo "error: version must be in X.Y.Z format (e.g. 1.2.3)" >&2
    exit 1
fi

echo "Building changelog for v$VERSION ..."
uv run towncrier build --yes --version "$VERSION"

echo ""
echo "Changelog built. Next steps:"
echo ""
echo "  git add CHANGELOG.md changelog.d/"
echo "  git commit -m \"Release v$VERSION\""
echo "  git tag v$VERSION"
echo "  git push origin main --tags"
echo "  gh release create v$VERSION --title \"v$VERSION\" --notes-file CHANGELOG.md"
